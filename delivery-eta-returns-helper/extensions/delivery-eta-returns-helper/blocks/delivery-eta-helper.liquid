<div
  class="eta-widget"
  data-base-time="{{ block.settings.base_time }}"
  data-order-time="{{ block.settings.order_time }}"
  data-cutoff-time="{{ block.settings.cutoff_time }}"
>
  <div class="delivery-wrapper">
    <label class="delivery-label">Please choose your area:</label>

    <select class="region">
      <option value="">Select a region</option>

      <option value="US">United States</option>

      <option value="CA">Canada</option>

      <option value="PH">Philippines</option>

      <option value="EU">Europe</option>

      <option value="GB">United Kingdom</option>
    </select>
  </div>

  <div class="delivery-wrapper">
    <p class="delivery-date"></p>

    <p class="delivery-message"></p>
  </div>

  <script type="application/json" class="product-json">
    {

      "available": {{ product.available | json }},

      "tags": {{ product.tags | json }},

      "variants": {{ product.variants | json }}

    }
  </script>

  <script type="application/json" class="region-rules-json">
    {
      "US": { "shipping_days": 1, "message": "US orders include prepaid returns." },

      "PH": { "shipping_days": 6, "message": "Free returns within 7 days in the Philippines." },

      "EU": { "shipping_days": 3, "message": "EU customers have a 14-day return window." },

      "CA": { "shipping_days": 2, "message": "Canada: Free returns within 30 days." },

      "GB": { "shipping_days": 4, "message": "UK: 14-day return policy applies." }
    }
  </script>
</div>

{{ 'delivery.css' | asset_url | stylesheet_tag }}

{{ 'delivery.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Delivery ETA Helper",

  "target": "section",

  "settings": [
    {
      "type": "number",

      "id": "base_time",

      "label": "Days (Base Time)",

      "default": 3
    },

    {
      "type": "number",

      "id": "order_time",

      "label": "Days (Order Lead Time)",

      "default": 14
    },

    {
      "type": "number",

      "id": "cutoff_time",

      "label": "Daily Cutoff",

      "default": 15
    }
  ]
}
{% endschema %}
